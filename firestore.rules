rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Simple single-business rule. For public production websites, add Firebase Auth.
    // This rule allows read/write only to your selected business document name.
    match /nextgen_album_billing_pro/{businessId} {
      allow read, write: if businessId == "nextgen-album-billing-pro";
    }
  }
}
